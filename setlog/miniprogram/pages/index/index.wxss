.page-shell {
  position: relative;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(105, 170, 255, 0.16), transparent 28%),
    radial-gradient(circle at top right, rgba(113, 239, 208, 0.12), transparent 22%),
    linear-gradient(180deg, #050816 0%, #08101f 45%, #060b14 100%);
  color: #eef4ff;
  overflow: hidden;
}

.ambient {
  position: absolute;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  filter: blur(20px);
  opacity: 0.5;
  pointer-events: none;
}

.ambient-left {
  top: -180rpx;
  left: -180rpx;
  background: radial-gradient(circle, rgba(121, 184, 255, 0.3), rgba(121, 184, 255, 0));
}

.ambient-right {
  top: 220rpx;
  right: -200rpx;
  background: radial-gradient(circle, rgba(125, 226, 197, 0.24), rgba(125, 226, 197, 0));
}

.scrollarea {
  position: relative;
  z-index: 1;
  height: 100vh;
}

.page {
  padding: calc(env(safe-area-inset-top) + 28rpx) 24rpx 36rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.topbar-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-mark {
  width: 60rpx;
  height: 60rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(121, 184, 255, 0.18), rgba(125, 226, 197, 0.24));
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: #f5f8ff;
  font-size: 34rpx;
  font-weight: 700;
}

.brand-name {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.brand-subtitle {
  margin-top: 2rpx;
  color: rgba(231, 238, 255, 0.62);
  font-size: 20rpx;
}

.topbar-chip,
.status-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.06);
  color: #e9f2ff;
  font-size: 22rpx;
}

.status-pill.subtle {
  color: rgba(234, 242, 255, 0.7);
}

.hero,
.panel,
.status-panel {
  margin-bottom: 20rpx;
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(7, 13, 26, 0.76);
  backdrop-filter: blur(16px);
  box-shadow: 0 24rpx 50rpx rgba(0, 0, 0, 0.22);
}

.hero {
  padding-top: 30rpx;
}

.eyebrow,
.panel-kicker {
  color: #8edbc9;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: 0;
}

.hero-copy {
  margin-top: 12rpx;
  color: rgba(228, 236, 255, 0.76);
  font-size: 26rpx;
  line-height: 1.6;
}

.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(121, 184, 255, 0.12);
  color: #cfe3ff;
  font-size: 22rpx;
  border: 1rpx solid rgba(121, 184, 255, 0.2);
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.metric-card {
  min-height: 128rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.metric-value {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.metric-label {
  display: block;
  margin-top: 10rpx;
  color: rgba(228, 236, 255, 0.68);
  font-size: 22rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  margin-top: 6rpx;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
}

.capture-grid,
.field-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.capture-summary {
  padding: 4rpx 0 10rpx;
}

.capture-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.capture-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.capture-label,
.label {
  color: rgba(227, 236, 255, 0.58);
  font-size: 22rpx;
}

.capture-value {
  color: #f3f7ff;
  font-size: 24rpx;
  text-align: right;
}

.field-full {
  grid-column: 1 / -1;
}

.field {
  min-width: 0;
}

.picker,
.input {
  margin-top: 10rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #f5f8ff;
  box-sizing: border-box;
}

.input-placeholder {
  color: rgba(227, 236, 255, 0.42);
}

.primary-button,
.secondary-button {
  margin-top: 18rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
  border: none;
}

.primary-button {
  background: linear-gradient(135deg, #8bc3ff 0%, #7de2c5 100%);
  color: #06111f;
}

.secondary-button {
  background: rgba(255, 255, 255, 0.06);
  color: #ecf2ff;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.hint-text {
  margin-top: 12rpx;
  color: rgba(228, 236, 255, 0.66);
  font-size: 22rpx;
  line-height: 1.6;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.timeline-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8bc3ff, #7de2c5);
  box-shadow: 0 0 0 8rpx rgba(125, 226, 197, 0.1);
  flex: none;
}

.timeline-body {
  flex: 1;
  min-width: 0;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.timeline-meta,
.timeline-note,
.empty-state,
.status-text,
.daily-line,
.log-meta,
.log-note {
  margin-top: 8rpx;
  color: rgba(228, 236, 255, 0.68);
  font-size: 24rpx;
  line-height: 1.6;
}

.timeline-tail {
  color: #eaf0ff;
  font-size: 24rpx;
  flex: none;
}

.empty-state {
  padding: 14rpx 0 4rpx;
}

.log-list {
  display: grid;
  gap: 14rpx;
}

.log-card {
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.log-card-active {
  background: linear-gradient(180deg, rgba(121, 184, 255, 0.12), rgba(255, 255, 255, 0.04));
  border-color: rgba(121, 184, 255, 0.22);
}

.log-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.log-name {
  font-size: 30rpx;
  font-weight: 700;
}

.log-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(121, 184, 255, 0.14);
  color: #cfe3ff;
  font-size: 22rpx;
  flex: none;
}

.daily-card {
  margin-top: 8rpx;
  padding: 18rpx 18rpx 6rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.status-panel {
  margin-bottom: 20rpx;
}

.status-title {
  font-size: 30rpx;
  font-weight: 700;
}

.status-text {
  margin-top: 10rpx;
}
